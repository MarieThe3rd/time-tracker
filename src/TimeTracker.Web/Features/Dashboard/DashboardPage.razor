@page "/"
@rendermode InteractiveServer
@inject DashboardHandler Handler
@inject IJSRuntime JS

<PageTitle>Dashboard — Time Tracker</PageTitle>

<h4 class="mb-4"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h4>

<!-- Date range picker -->
<div class="d-flex gap-2 align-items-center mb-3 flex-wrap">
    <span class="text-muted small fw-semibold">Showing:</span>
    <button class="btn btn-sm @ActiveClass("today")" @onclick='() => SetPreset("today")'>Today</button>
    <button class="btn btn-sm @ActiveClass("week")" @onclick='() => SetPreset("week")'>This Week</button>
    <button class="btn btn-sm @ActiveClass("month")" @onclick='() => SetPreset("month")'>This Month</button>
    <button class="btn btn-sm @ActiveClass("custom")" @onclick='() => SetPreset("custom")'>Custom</button>
    @if (_preset == "custom")
    {
        <input type="date" class="form-control form-control-sm" style="width:140px"
               @bind="_from" @bind:after="LoadDashboard" />
        <span class="text-muted">–</span>
        <input type="date" class="form-control form-control-sm" style="width:140px"
               @bind="_to" @bind:after="LoadDashboard" />
    }
    <span class="text-muted small ms-2">@_dateLabel</span>
</div>

@if (_data is null)
{
    <p class="text-muted">Loading…</p>
}
else
{
    <!-- Summary cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <div class="text-muted small mb-1">Total Time</div>
                    <div class="fs-3 fw-bold">@FormatSpan(_data.TotalTime)</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <div class="text-muted small mb-1">Avg Productivity</div>
                    <div class="fs-3 fw-bold">
                        @if (_data.AvgProductivity > 0)
                        {
                            @($"{_data.AvgProductivity:F1}") <span class="fs-6 text-warning">★</span>
                        }
                        else
                        {
                            <span class="text-muted fs-6">No ratings yet</span>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card shadow-sm text-center">
                <div class="card-body">
                    <div class="text-muted small mb-1">Total Entries</div>
                    <div class="fs-3 fw-bold">@_data.EntryCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card shadow-sm text-center h-100">
                <div class="card-body">
                    <div class="text-muted small mb-1">AI Time Saved</div>
                    <div class="fs-3 fw-bold">@TimeFormatHelper.FormatMinutes(_data.AiSummary.TimeSavedMinutes)</div>
                    <div class="small text-muted mt-2">
                        Assisted entries: @_data.AiSummary.AssistedEntries
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Donut chart -->
        <div class="col-lg-5">
            <div class="card shadow-sm h-100">
                <div class="card-header fw-semibold">Time by Category</div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    @if (_data.CategoryStats.Count == 0)
                    {
                        <p class="text-muted">No completed entries in this range.</p>
                    }
                    else
                    {
                        <div style="height:260px;width:100%">
                            <canvas id="categoryDonut"></canvas>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Recent entries -->
        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold">Recent Entries</div>
                <div class="card-body p-0">
                    @if (_data.RecentEntries.Count == 0)
                    {
                        <p class="text-muted p-3 mb-0">No entries in this range.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var e in _data.RecentEntries)
                            {
                                <li class="list-group-item d-flex align-items-center gap-2">
                                    @if (e.WorkCategory is not null)
                                    {
                                        <span class="badge" style="background-color:@e.WorkCategory.Color">@e.WorkCategory.Name</span>
                                    }
                                    <span class="flex-grow-1 small text-truncate">@(e.Description ?? "—")</span>
                                    @if (e.AiUsed)
                                    {
                                        <span class="badge text-bg-info">AI @TimeFormatHelper.FormatMinutes(e.AiTimeSavedMinutes)</span>
                                    }
                                    <span class="text-muted small text-nowrap">@FormatSpan(e.Duration)</span>
                                    @if (e.ProductivityRating.HasValue)
                                    {
                                        <span class="text-warning small">@("★".PadRight(e.ProductivityRating.Value, '★').TrimEnd())</span>
                                    }
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>

            <!-- Recent journal -->
            <div class="card shadow-sm mt-3">
                <div class="card-header fw-semibold">Recent Journal</div>
                <div class="card-body p-0">
                    @if (_data.RecentJournal.Count == 0)
                    {
                        <p class="text-muted p-3 mb-0">No journal entries yet.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var j in _data.RecentJournal)
                            {
                                var jIcon  = j.JournalType?.Icon  ?? "bi-journal";
                                var jColor = j.JournalType?.Color ?? "#6c757d";
                                <li class="list-group-item d-flex align-items-start gap-2">
                                    <span class="badge mt-1" style="background-color:@jColor"><i class="bi @jIcon"></i></span>
                                    <div>
                                        <div class="small fw-semibold">@j.Title</div>
                                        <div class="text-muted" style="font-size:.8rem">@j.Date.ToString("MMM d")</div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DashboardData? _data;
    private string _preset = "today";
    private DateOnly _from = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly _to = DateOnly.FromDateTime(DateTime.Today);

    private DateOnly _weekStart => GetWeekStart(DateOnly.FromDateTime(DateTime.Today));

    private string _dateLabel => _preset switch
    {
        "today" => DateTime.Today.ToString("dddd, MMMM d"),
        "week" => $"Week of {_weekStart:MMM d}",
        "month" => DateTime.Today.ToString("MMMM yyyy"),
        _ => $"{_from:MMM d} – {_to:MMM d, yyyy}"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboard();
    }

    private async Task SetPreset(string preset)
    {
        _preset = preset;
        var today = DateOnly.FromDateTime(DateTime.Today);
        (_from, _to) = preset switch
        {
            "today" => (today, today),
            "week" => (GetWeekStart(today), today),
            "month" => (new DateOnly(today.Year, today.Month, 1), today),
            _ => (_from, _to)
        };
        await LoadDashboard();
    }

    private async Task LoadDashboard()
    {
        _data = await Handler.HandleAsync(_from, _to);
    }

    private string ActiveClass(string preset) =>
        _preset == preset ? "btn-primary" : "btn-outline-secondary";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_data?.CategoryStats.Count > 0)
        {
            await JS.InvokeVoidAsync("renderDonutChart",
                "categoryDonut",
                _data.CategoryStats.Select(s => s.Name).ToArray(),
                _data.CategoryStats.Select(s => s.TotalHours).ToArray(),
                _data.CategoryStats.Select(s => s.Color).ToArray());
        }
    }

    private static DateOnly GetWeekStart(DateOnly date)
    {
        var diff = ((int)date.DayOfWeek - (int)DayOfWeek.Monday + 7) % 7;
        return date.AddDays(-diff);
    }

    private static string FormatSpan(TimeSpan? ts)
    {
        if (ts is null) return "—";
        return $"{(int)ts.Value.TotalHours}h {ts.Value.Minutes}m";
    }
}

