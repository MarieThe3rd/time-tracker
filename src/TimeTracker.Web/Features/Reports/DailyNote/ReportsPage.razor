@page "/reports"
@rendermode InteractiveServer
@using TimeTracker.Web.Features.Reports.AiUsage
@using TimeTracker.Web.Data.Repositories
@inject ReportsHandler Handler
@inject MarkdownExportService MarkdownService
@inject IUserSettingsRepository _settingsRepo
@inject IJSRuntime JS
@inject TimeTracker.Web.Data.Repositories.IJournalTypeRepository JournalTypeRepo

<PageTitle>Reports — Time Tracker</PageTitle>

<h4 class="mb-4"><i class="bi bi-bar-chart-line me-2"></i>Reports</h4>

<!-- Date range picker -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label" for="reportPreset">Preset</label>
                <select id="reportPreset" class="form-select" @bind="_preset" @bind:after="ApplyPreset">
                    <option value="today">Today</option>
                    <option value="week">This week</option>
                    <option value="month">This month</option>
                    <option value="custom">Custom</option>
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label" for="reportFrom">From</label>
                <input id="reportFrom" type="date" class="form-control" @bind="_from" @bind:after="LoadData" />
            </div>
            <div class="col-auto">
                <label class="form-label" for="reportTo">To</label>
                <input id="reportTo" type="date" class="form-control" @bind="_to" @bind:after="LoadData" />
            </div>
            <div class="col-auto">
                <label class="form-label" for="reportDay">Day</label>
                <input id="reportDay" type="date" class="form-control" @bind="_dailyDate"
                       @bind:after="ApplyDailyDate" />
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small mb-1">Logged Time</div>
                <div class="fs-4 fw-bold">@FormatHours(_entries.Where(e => e.Duration.HasValue).Sum(e =>
                                                                                e.Duration!.Value.TotalHours))</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small mb-1">AI-Assisted Entries</div>
                    <div class="fs-4 fw-bold">@AiEntries.Count</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small mb-1">AI Time Saved</div>
                    <div class="fs-4 fw-bold">@TimeFormatHelper.FormatMinutes(TotalAiTimeSavedMinutes)</div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small mb-1">Journal Entries</div>
                    <div class="fs-4 fw-bold">@_journal.Count</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tab selector -->
    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <button class="nav-link @(_tab == "summary" ? "active" : "")"
                    @onclick='() => SelectTab("summary")'>Summary</button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(_tab == "ai" ? "active" : "")" @onclick='() => SelectTab("ai")'>AI Insights</button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(_tab == "daily" ? "active" : "")" @onclick='() => SelectTab("daily")'>Daily
                Note</button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(_tab == "weekly" ? "active" : "")" @onclick='() => SelectTab("weekly")'>Weekly
                    Summary</button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(_tab == "review" ? "active" : "")" @onclick='() => SelectTab("review")'>Review
                        Export</button>
                    </li>
                </ul>

                @if (_tab == "summary")
                {
                    <!-- Category breakdown -->
                    <div class="card shadow-sm">
                        <div class="card-header fw-semibold">Time by Category</div>
                        <div class="card-body">
                            @if (_entries.Count == 0)
                            {
                                <p class="text-muted">No entries in this range.</p>
                            }
                            else
                            {
                                var total = _entries.Where(e => e.Duration.HasValue).Sum(e => e.Duration!.Value.TotalHours);
                                <p class="text-muted small">Total: <strong>@FormatHours(total)</strong></p>
                                @foreach (var g in _entries
                                                                                                                                            .Where(e => e.Duration.HasValue && e.WorkCategory != null)
                                                                                                                                            .GroupBy(e => e.WorkCategory!)
                                                                                                                                            .Select(g => (Cat: g.Key, Hours: g.Sum(e => e.Duration!.Value.TotalHours)))
                                                                                                                                            .OrderByDescending(x => x.Hours))
                                {
                                    var pct = total > 0 ? (int)(g.Hours / total * 100) : 0;
                                    <div class="mb-2">
                                        <div class="d-flex justify-content-between small mb-1">
                                            <span>
                                                <span class="badge me-1" style="background-color:@g.Cat.Color">@g.Cat.Name</span>
                                            </span>
                                            <span>@FormatHours(g.Hours) (@pct%)</span>
                                        </div>
                                        <div class="progress" style="height:8px">
                                            <div class="progress-bar" style="width:@pct%;background-color:@g.Cat.Color"></div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }

                @if (_tab == "ai")
                {
                    @if (AiEntries.Count == 0)
                    {
                        <div class="card shadow-sm">
                            <div class="card-body">
                                <p class="text-muted mb-0">No AI-assisted entries in this range.</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <div class="card shadow-sm h-100">
                                    <div class="card-body text-center">
                                        <div class="text-muted small mb-1">AI-Assisted Work</div>
                                        <div class="fs-3 fw-bold">@AiEntries.Count</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card shadow-sm h-100">
                                    <div class="card-body text-center">
                                        <div class="text-muted small mb-1">Time Saved</div>
                                        <div class="fs-3 fw-bold">@TimeFormatHelper.FormatMinutes(TotalAiTimeSavedMinutes)</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card shadow-sm h-100">
                                    <div class="card-body text-center">
                                        <div class="text-muted small mb-1">Avg Saved Per Entry</div>
                                        <div class="fs-3 fw-bold">@TimeFormatHelper.FormatMinutes(AverageAiTimeSavedMinutes)</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card shadow-sm mb-4">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <span class="fw-semibold">AI Savings Summary</span>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="DownloadAiReport">
                                        <i class="bi bi-download me-1"></i>Download AI Report
                                    </button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="ExportAiReport">
                                        <i class="bi bi-cloud-upload me-1"></i>Export AI Report
                                    </button>
                                </div>
                            </div>
                            <div class="card-body">
                                @if (!string.IsNullOrEmpty(_statusMessage))
                                {
                                    <div class="alert @(_statusIsError ? "alert-danger" : "alert-success") py-2 mb-3">@_statusMessage</div>
                                }
                                <p class="fs-5 mb-1">
                                    <i class="bi bi-robot me-2 text-info"></i>
                                    <strong>@TimeFormatHelper.FormatMinutes(TotalAiTimeSavedMinutes)</strong> saved using AI
                                    across <strong>@AiEntries.Count</strong> @(AiEntries.Count == 1 ? "entry" : "entries")
                                    in the selected period.
                                </p>
                                @if (AiEntries.Count > 0)
                                {
                                    <p class="text-muted small mb-0">
                                        Average per entry: <strong>@TimeFormatHelper.FormatMinutes(AverageAiTimeSavedMinutes)</strong>
                                    </p>
                                }
                            </div>
                        </div>

                        <div class="card shadow-sm mb-4">
                            <div class="card-header fw-semibold">Weekly AI Summary</div>
                            <div class="card-body p-0">
                                <table class="table table-sm table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Week Start</th>
                                            <th>Week End</th>
                                            <th>AI Tasks</th>
                                            <th>Time Saved</th>
                                            <th>Value Added</th>
                                            <th>Notes</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var week in _aiWeeks)
                                        {
                                            <tr>
                                                <td>@week.WeekStart.ToString("yyyy-MM-dd")</td>
                                                <td>@week.WeekEnd.ToString("yyyy-MM-dd")</td>
                                                <td>@week.AiTaskCount</td>
                                                <td>@TimeFormatHelper.FormatMinutes(week.TotalTimeSavedMinutes)</td>
                                                <td>@(string.IsNullOrWhiteSpace(week.ValueAdded) ? "—" : week.ValueAdded)</td>
                                                <td>@(string.IsNullOrWhiteSpace(week.Notes) ? "—" : week.Notes)</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        @if (_aiWeeks.Any(w => !string.IsNullOrWhiteSpace(w.ValueAdded) || !string.IsNullOrWhiteSpace(w.Notes)))
                        {
                            <div class="card shadow-sm">
                                <div class="card-header fw-semibold">Qualitative Insights</div>
                                <div class="card-body">
                                    @foreach (var week in _aiWeeks.Where(w => !string.IsNullOrWhiteSpace(w.ValueAdded) ||
                                                                                                                    !string.IsNullOrWhiteSpace(w.Notes)))
                                    {
                                        <div class="mb-3">
                                            <strong>@week.WeekStart.ToString("yyyy-MM-dd") – @week.WeekEnd.ToString("yyyy-MM-dd")</strong>
                                            @if (!string.IsNullOrWhiteSpace(week.ValueAdded))
                                            {
                                                <div class="text-muted small"><span class="fw-semibold">Value Added:</span> @week.ValueAdded</div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(week.Notes))
                                            {
                                                <div class="text-muted small"><span class="fw-semibold">Notes:</span> @week.Notes</div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                }

                @if (_tab is "daily" or "weekly" or "review")
                {
                    var dailyDate = _from.ToDateTime(TimeOnly.MinValue).Date;
                    var dailyEntries = _entries
                        .Where(e => e.StartTime.ToLocalTime().Date == dailyDate)
                        .OrderBy(e => e.StartTime)
                        .ToList();
                    var dailyJournal = _journal.Where(j => j.Date == _from).ToList();

                    var markdown = _tab switch
                    {
                        "daily" => MarkdownService.BuildDailyNote(
                            _from,
                            dailyEntries,
                            dailyJournal,
                            dailyEntries.Where(e => e.ProductivityRating.HasValue && !e.IsBreak)
                                .Select(e => (double)e.ProductivityRating!.Value)
                                .DefaultIfEmpty(0).Average(),
                            _tasks),
                        "weekly" => MarkdownService.BuildWeeklySummary(_from, _to, _entries, _journal, _tasks),
                        "review" => MarkdownService.BuildReviewExport(_from, _to, _journal, _entries, _tasks),
                        _ => string.Empty
                    };

                    <div class="card shadow-sm">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <span class="fw-semibold">
                                @if (_tab == "daily") { <i class="bi bi-calendar-day me-1"></i> }
                                else if (_tab == "weekly") { <i class="bi bi-calendar-week me-1"></i> }
                                else { <i class="bi bi-clipboard-check me-1"></i> }
                                @(_tab == "daily" ? _from.ToString("dddd, MMMM d, yyyy")
                                  : _tab == "weekly" ? $"Weekly Summary: {_from:MMM d} – {_to:MMM d, yyyy}"
                                  : $"Review Export: {_from:MMM d} – {_to:MMM d, yyyy}")
                            </span>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => CopyToClipboard(markdown)">
                                    <i class="bi bi-clipboard me-1"></i>Copy
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => DownloadMarkdown(markdown)">
                                    <i class="bi bi-download me-1"></i>Download .md
                                </button>
                                @if (_tab == "daily")
                                {
                                    <button class="btn btn-sm btn-success" @onclick="() => PushToObsidian(markdown)">
                                        <i class="bi bi-journal-arrow-up me-1"></i>Push to Obsidian
                                    </button>
                                }
                                else if (_tab == "weekly")
                                {
                                    <button class="btn btn-sm btn-success" @onclick="() => PushWeeklyToObsidian(markdown)">
                                        <i class="bi bi-journal-arrow-up me-1"></i>Push to Obsidian
                                    </button>
                                }
                            </div>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(_statusMessage))
                            {
                                <div class="alert @(_statusIsError ? "alert-danger" : "alert-success") py-2 mb-3">@_statusMessage</div>
                            }

                            @if (_tab == "daily")
                            {
                                <!-- Daily Note: time entries table + journal sections -->
                                @if (dailyEntries.Count == 0)
                                {
                                    <p class="text-muted">No entries for @_from.ToString("MMMM d, yyyy").</p>
                                }
                                else
                                {
                                    <h6 class="fw-semibold mb-2">Time Entries</h6>
                                    <div class="table-responsive mb-4">
                                        <table class="table table-sm table-hover align-middle">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Time</th>
                                                    <th>Category</th>
                                                    <th>Description</th>
                                                    <th>Duration</th>
                                                    <th>Productivity</th>
                                                    <th>AI?</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var e in dailyEntries)
                                                {
                                                    <tr>
                                                        <td class="text-nowrap text-muted small">@e.StartTime.ToLocalTime().ToString("HH:mm")</td>
                                                        <td>
                                                            @if (e.WorkCategory != null)
                                                            {
                                                                <span class="badge" style="background-color:@e.WorkCategory.Color">@e.WorkCategory.Name</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-muted">—</span>
                                                            }
                                                        </td>
                                                        <td>@(e.Description ?? "—")</td>
                                                        <td class="text-nowrap">@(e.Duration.HasValue ? FormatHours(e.Duration.Value.TotalHours) : "—")</td>
                                                        <td>
                                                            @if (e.ProductivityRating.HasValue)
                                                            {
                                                                <span class="text-warning">@(new string('★', e.ProductivityRating.Value))</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-muted">—</span>
                                                            }
                                                        </td>
                                                        <td>
                                                            @if (e.AiUsed)
                                                            {
                                                                <span class="badge text-bg-info">AI @TimeFormatHelper.FormatMinutes(e.AiTimeSavedMinutes)</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-muted">—</span>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }

                                @if (dailyJournal.Count > 0)
                                {
                                    <h6 class="fw-semibold mb-2">Journal</h6>
                                    @foreach (var typeGroup in dailyJournal.GroupBy(j => j.JournalTypeId).OrderBy(g => g.Key))
                                    {
                                        var jt = _journalTypes.FirstOrDefault(t => t.Id == typeGroup.Key);
                                        var jIcon  = jt?.Icon  ?? "bi-journal";
                                        var jColor = jt?.Color ?? "#6c757d";
                                        var jName  = jt?.Name  ?? typeGroup.Key.ToString();
                                        <div class="mb-3">
                                            <div class="mb-2">
                                                <span class="badge" style="background-color:@jColor"><i class="bi @jIcon me-1"></i>@jName</span>
                                            </div>
                                            @foreach (var j in typeGroup)
                                            {
                                                <div class="ms-3 mb-2">
                                                    <div class="fw-semibold small">@j.Title</div>
                                                    @if (!string.IsNullOrWhiteSpace(j.Body))
                                                    {
                                                        <div class="text-muted small">@j.Body</div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                }
                                else if (dailyEntries.Count == 0)
                                {
                                    <p class="text-muted small">No journal entries for this day.</p>
                                }
                            }
                            else if (_tab == "weekly")
                            {
                                <!-- Weekly Summary: stats + category breakdown + day-grouped entries -->
                                var weekTotal = _entries.Where(e => e.Duration.HasValue).Sum(e => e.Duration!.Value.TotalHours);
                                var weekTopCat = _entries
                                    .Where(e => e.Duration.HasValue && e.WorkCategory != null)
                                    .GroupBy(e => e.WorkCategory!)
                                    .Select(g => (Cat: g.Key, Hours: g.Sum(e => e.Duration!.Value.TotalHours)))
                                    .OrderByDescending(x => x.Hours)
                                    .FirstOrDefault();
                                var weekCatBreakdown = _entries
                                    .Where(e => e.Duration.HasValue && e.WorkCategory != null)
                                    .GroupBy(e => e.WorkCategory!)
                                    .Select(g => (Cat: g.Key, Hours: g.Sum(e => e.Duration!.Value.TotalHours)))
                                    .OrderByDescending(x => x.Hours)
                                    .ToList();

                                <div class="row g-3 mb-4">
                                    <div class="col-md-6">
                                        <div class="border rounded p-3 text-center">
                                            <div class="text-muted small mb-1">Total Hours</div>
                                            <div class="fs-4 fw-bold">@FormatHours(weekTotal)</div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="border rounded p-3 text-center">
                                            <div class="text-muted small mb-1">Top Category</div>
                                            <div class="fs-5 fw-bold mt-1">
                                                @if (weekTopCat.Cat != null)
                                                {
                                                    <span class="badge" style="background-color:@weekTopCat.Cat.Color">@weekTopCat.Cat.Name</span>
                                                    <span class="text-muted small ms-1">@FormatHours(weekTopCat.Hours)</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted fs-6">—</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                @if (weekCatBreakdown.Count > 0)
                                {
                                    <h6 class="fw-semibold mb-2">By Category</h6>
                                    @foreach (var (cat, hours) in weekCatBreakdown)
                                    {
                                        var pct = weekTotal > 0 ? (int)(hours / weekTotal * 100) : 0;
                                        <div class="mb-2">
                                            <div class="d-flex justify-content-between small mb-1">
                                                <span><span class="badge me-1" style="background-color:@cat.Color">@cat.Name</span></span>
                                                <span>@FormatHours(hours) (@pct%)</span>
                                            </div>
                                            <div class="progress" style="height:8px">
                                                <div class="progress-bar" style="width:@pct%;background-color:@cat.Color"></div>
                                            </div>
                                        </div>
                                    }
                                    <hr />
                                }

                                <h6 class="fw-semibold mb-2">Entries by Day</h6>
                                @if (_entries.Count == 0)
                                {
                                    <p class="text-muted">No entries in this range.</p>
                                }
                                else
                                {
                                    @foreach (var dayGroup in _entries
                                        .GroupBy(e => DateOnly.FromDateTime(e.StartTime.ToLocalTime()))
                                        .OrderBy(g => g.Key))
                                    {
                                        <div class="mb-3">
                                            <div class="fw-semibold small text-muted mb-1">@dayGroup.Key.ToString("dddd, MMMM d")</div>
                                            <div class="table-responsive">
                                                <table class="table table-sm table-hover align-middle mb-0">
                                                    <tbody>
                                                        @foreach (var e in dayGroup.OrderBy(e => e.StartTime))
                                                        {
                                                            <tr>
                                                                <td class="text-nowrap text-muted small" style="width:55px">@e.StartTime.ToLocalTime().ToString("HH:mm")</td>
                                                                <td style="width:120px">
                                                                    @if (e.WorkCategory != null)
                                                                    {
                                                                        <span class="badge" style="background-color:@e.WorkCategory.Color">@e.WorkCategory.Name</span>
                                                                    }
                                                                </td>
                                                                <td>@(e.Description ?? "—")</td>
                                                                <td class="text-nowrap" style="width:75px">@(e.Duration.HasValue ? FormatHours(e.Duration.Value.TotalHours) : "—")</td>
                                                                <td style="width:50px">
                                                                    @if (e.AiUsed)
                                                                    {
                                                                        <span class="badge text-bg-info">AI</span>
                                                                    }
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    }
                                }
                            }
                            else if (_tab == "review")
                            {
                                <!-- Review Export: Successes, Challenges, Learnings as card sections -->
                                var successes  = _journal.Where(j => j.JournalTypeId == 3).OrderBy(j => j.Date).ToList();
                                var challenges = _journal.Where(j => j.JournalTypeId == 1).OrderBy(j => j.Date).ToList();
                                var learnings  = _journal.Where(j => j.JournalTypeId == 2).OrderBy(j => j.Date).ToList();

                                @if (successes.Count == 0 && challenges.Count == 0 && learnings.Count == 0)
                                {
                                    <p class="text-muted">No journal entries in this range.</p>
                                }

                                @if (successes.Count > 0)
                                {
                                    <div class="mb-4">
                                        <h6 class="mb-2"><span class="badge bg-success me-2"><i class="bi bi-trophy me-1"></i>Successes &amp; Wins</span></h6>
                                        @foreach (var j in successes)
                                        {
                                            <div class="card shadow-sm mb-2">
                                                <div class="card-body py-2">
                                                    <div class="small fw-semibold">@j.Date.ToString("MMM d, yyyy") — @j.Title</div>
                                                    @if (!string.IsNullOrWhiteSpace(j.Body))
                                                    {
                                                        <div class="text-muted small mt-1">@j.Body</div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }

                                @if (challenges.Count > 0)
                                {
                                    <div class="mb-4">
                                        <h6 class="mb-2"><span class="badge bg-warning text-dark me-2"><i class="bi bi-lightning-charge me-1"></i>Challenges</span></h6>
                                        @foreach (var j in challenges)
                                        {
                                            <div class="card shadow-sm mb-2">
                                                <div class="card-body py-2">
                                                    <div class="small fw-semibold">@j.Date.ToString("MMM d, yyyy") — @j.Title</div>
                                                    @if (!string.IsNullOrWhiteSpace(j.Body))
                                                    {
                                                        <div class="text-muted small mt-1">@j.Body</div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }

                                @if (learnings.Count > 0)
                                {
                                    <div class="mb-4">
                                        <h6 class="mb-2"><span class="badge bg-info text-dark me-2"><i class="bi bi-mortarboard me-1"></i>Learnings</span></h6>
                                        @foreach (var j in learnings)
                                        {
                                            <div class="card shadow-sm mb-2">
                                                <div class="card-body py-2">
                                                    <div class="small fw-semibold">@j.Date.ToString("MMM d, yyyy") — @j.Title</div>
                                                    @if (!string.IsNullOrWhiteSpace(j.Body))
                                                    {
                                                        <div class="text-muted small mt-1">@j.Body</div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }

@code {
    private List<TimeEntry> _entries = [];
    private List<JournalEntry> _journal = [];
    private List<AiUsageWeeklyItem> _aiWeeks = [];
    private List<JournalType> _journalTypes = [];
    private List<TaskItem> _tasks = [];
    private UserSettings _settings = new();
    private string _tab = "summary";
    private string _preset = "week";
    private DateOnly _from = GetWeekStart(DateOnly.FromDateTime(DateTime.Today));
    private DateOnly _to = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly _dailyDate = DateOnly.FromDateTime(DateTime.Today);
    private string? _statusMessage;
    private bool _statusIsError;

    private List<TimeEntry> AiEntries => _entries.Where(e => e.AiUsed).OrderBy(e => e.StartTime).ToList();
    private int TotalAiTimeSavedMinutes => AiEntries.Sum(e => e.AiTimeSavedMinutes ?? 0);
    private int AverageAiTimeSavedMinutes => AiEntries.Count == 0
        ? 0
        : (int)Math.Round(AiEntries.Average(e => e.AiTimeSavedMinutes ?? 0));

    protected override async Task OnInitializedAsync()
    {
        _settings = await _settingsRepo.GetAsync();
        _journalTypes = await JournalTypeRepo.GetAllAsync();
        await ApplyPreset();
    }

    private async Task ApplyPreset()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        (_from, _to) = _preset switch
        {
            "today" => (today, today),
            "week" => (GetWeekStart(today), today),
            "month" => (new DateOnly(today.Year, today.Month, 1), today),
            _ => (_from, _to)
        };

        if (_from == _to)
        {
            _dailyDate = _from;
        }

        await LoadData();
    }

    private async Task ApplyDailyDate()
    {
        _preset = "custom";
        _from = _dailyDate;
        _to = _dailyDate;
        await LoadData();
    }

    private async Task LoadData()
    {
        if (_from > _to)
        {
            ShowStatus("From date must be on or before To date.", true);
            return;
        }

        var range = new ReportRange(_from, _to);
        (_entries, _journal) = await Handler.GetRangeDataAsync(range);
        _aiWeeks = await Handler.GetWeeklyAiUsageAsync(range);
        _tasks = await Handler.GetTasksForRangeAsync(range);
        if (_from == _to)
        {
            _dailyDate = _from;
        }
        ShowStatus(string.Empty, false);
    }

    private void SelectTab(string tab)
    {
        _tab = tab;
    }

    private async Task CopyToClipboard(string text)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
        ShowStatus("Copied to clipboard!", false);
    }

    private async Task DownloadMarkdown(string text)
    {
        var filename = _tab == "daily" ? $"{_from:yyyy-MM-dd}.md"
                     : _tab == "review" ? $"review-{_from:yyyy-MM-dd}-{_to:yyyy-MM-dd}.md"
                     : $"weekly-{_from:yyyy-MM-dd}-{_to:yyyy-MM-dd}.md";

        var bytes = System.Text.Encoding.UTF8.GetBytes(text);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadBase64File", filename, base64);
    }

    private async Task PushToObsidian(string markdown)
    {
        _statusMessage = null;
        try
        {
            var (path, appended) = await Handler.PushDailyNoteAsync(_from, markdown, _settings);
            ShowStatus($"{(appended ? "Appended to" : "Saved to")} {path}", false);
        }
        catch (Exception ex)
        {
            ShowStatus(ex.Message, true);
        }
    }

    private async Task PushWeeklyToObsidian(string markdown)
    {
        _statusMessage = null;
        try
        {
            var range = new ReportRange(_from, _to);
            var (path, overwritten) = await Handler.PushWeeklySummaryAsync(range, markdown, _settings);
            ShowStatus(overwritten ? $"File overwritten at {path}" : $"Saved to {path}", false);
        }
        catch (Exception ex)
        {
            ShowStatus(ex.Message, true);
        }
    }

    private async Task DownloadAiReport()
    {
        var markdown = MarkdownService.BuildAiUsageWeeklyReport(_from, _to, _aiWeeks);
        var filename = $"AI-Usage-Report-{_from:yyyy-MM-dd}-to-{_to:yyyy-MM-dd}.md";
        var bytes = System.Text.Encoding.UTF8.GetBytes(markdown);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadBase64File", filename, base64);
    }

    private async Task ExportAiReport()
    {
        _statusMessage = null;
        try
        {
            var markdown = MarkdownService.BuildAiUsageWeeklyReport(_from, _to, _aiWeeks);
            var (path, overwritten) = await Handler.PushAiUsageReportAsync(_from, _to, markdown, _settings);
            ShowStatus(overwritten ? $"File overwritten at {path}" : $"Exported to {path}", false);
        }
        catch (Exception ex)
        {
            ShowStatus(ex.Message, true);
        }
    }

    private void ShowStatus(string msg, bool isError)
    {
        _statusMessage = string.IsNullOrWhiteSpace(msg) ? null : msg;
        _statusIsError = isError;
    }

    private static DateOnly GetWeekStart(DateOnly date)
    {
        var diff = ((int)date.DayOfWeek - (int)DayOfWeek.Monday + 7) % 7;
        return date.AddDays(-diff);
    }

    private static string FormatHours(double hours)
    {
        var h = (int)hours;
        var m = (int)Math.Round((hours - h) * 60);
        return $"{h}h {m}m";
    }
}
