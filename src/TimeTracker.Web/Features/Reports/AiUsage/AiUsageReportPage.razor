@page "/reports/ai-usage"
@rendermode InteractiveServer
@inject AiUsageReportHandler Handler
@inject AppDbContext Db
@inject IJSRuntime JS

<PageTitle>AI Usage Report</PageTitle>

<h4 class="mb-4"><i class="bi bi-cpu me-2"></i>AI Usage Report</h4>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label">From</label>
                <input type="date" class="form-control" @bind="_from" @bind:after="LoadData" />
            </div>
            <div class="col-auto">
                <label class="form-label">To</label>
                <input type="date" class="form-control" @bind="_to" @bind:after="LoadData" />
            </div>
        </div>
    </div>
</div>

@if (_items.Count == 0)
{
    <p class="text-muted">No AI usage entries in this range.</p>
}
else
{
    <div class="card shadow-sm mb-4">
        <div class="card-header fw-semibold">AI Usage Over Time</div>
        <div class="card-body">
            <canvas id="aiUsageChart" height="120"></canvas>
        </div>
    </div>
    <div class="card shadow-sm">
        <div class="card-header fw-semibold">AI Usage Details</div>
        <div class="card-body p-0">
            <table class="table table-sm table-hover mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Time Saved (min)</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _items)
                    {
                        <tr>
                            <td>@item.StartTime.ToLocalTime().ToShortDateString()</td>
                            <td>@item.Description</td>
                            <td>@item.AiTimeSavedMinutes</td>
                            <td>@item.AiNotes</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<AiUsageReportItem> _items = [];
    private DateOnly _from = DateOnly.FromDateTime(DateTime.Today.AddDays(-30));
    private DateOnly _to = DateOnly.FromDateTime(DateTime.Today);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var from = _from.ToDateTime(TimeOnly.MinValue).ToUniversalTime();
        var to = _to.ToDateTime(TimeOnly.MaxValue).ToUniversalTime();
        _items = await Handler.GetAiUsageAsync(from, to);
        await RenderChart();
    }

    private async Task RenderChart()
    {
        var chartData = _items
            .GroupBy(i => i.StartTime.Date)
            .Select(g => new { Date = g.Key, Count = g.Count(), TotalSaved = g.Sum(x => x.AiTimeSavedMinutes ?? 0) })
            .OrderBy(x => x.Date)
            .ToList();
        await JS.InvokeVoidAsync("renderAiUsageChart", chartData.Select(x => x.Date.ToShortDateString()), chartData.Select(x => x.Count), chartData.Select(x => x.TotalSaved));
    }
}
