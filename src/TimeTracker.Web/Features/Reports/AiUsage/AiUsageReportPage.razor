@page "/reports/ai-usage"
@rendermode InteractiveServer
@using System.Text
@using TimeTracker.Web.Features.Reports.DailyNote
@using TimeTracker.Web.Features.Settings
@inject AiUsageReportHandler Handler
@inject ReportsHandler ReportsHandler
@inject MarkdownExportService ExportService
@inject SettingsHandler SettingsHandler
@inject IJSRuntime JS

<PageTitle>AI Usage Report</PageTitle>

<h4 class="mb-4"><i class="bi bi-cpu me-2"></i>AI Usage Report</h4>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label" for="fromDate">From</label>
                <input id="fromDate" type="date" class="form-control" @bind="_from" @bind:after="LoadData" />
            </div>
            <div class="col-auto">
                <label class="form-label" for="toDate">To</label>
                <input id="toDate" type="date" class="form-control" @bind="_to" @bind:after="LoadData" />
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-primary" @onclick="ExportToObsidian" disabled="@_exporting">
                    <i class="bi bi-cloud-upload me-1"></i>Export to Obsidian
                </button>
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-secondary" @onclick="DownloadMarkdown">
                    <i class="bi bi-download me-1"></i>Download
                </button>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(_statusMessage))
        {
            <div class="mt-2 alert @(_statusIsError ? "alert-danger" : "alert-success") py-1 px-2 mb-0">@_statusMessage</div>
        }
    </div>
</div>

@if (_weeks.Count == 0)
{
    <p class="text-muted">No AI usage entries in this range.</p>
}
else
{
    <div class="card shadow-sm mb-4">
        <div class="card-header fw-semibold">AI Usage Over Time (Weekly)</div>
        <div class="card-body">
            <canvas id="aiUsageChart" height="120"></canvas>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header fw-semibold">Weekly Summary</div>
        <div class="card-body p-0">
            <table class="table table-sm table-hover mb-0">
                <thead>
                    <tr>
                        <th>Week Start</th>
                        <th>Week End</th>
                        <th>AI Tasks Count</th>
                        <th>Total Time Saved (min)</th>
                        <th>Value Added</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var week in _weeks)
                    {
                        <tr>
                            <td>@week.WeekStart.ToString("yyyy-MM-dd")</td>
                            <td>@week.WeekEnd.ToString("yyyy-MM-dd")</td>
                            <td>@week.AiTaskCount</td>
                            <td>@week.TotalTimeSavedMinutes</td>
                            <td>@(string.IsNullOrWhiteSpace(week.ValueAdded) ? "—" : week.ValueAdded)</td>
                            <td>@(string.IsNullOrWhiteSpace(week.Notes) ? "—" : week.Notes)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (_weeks.Any(w => !string.IsNullOrWhiteSpace(w.ValueAdded) || !string.IsNullOrWhiteSpace(w.Notes)))
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header fw-semibold">Qualitative Insights</div>
            <div class="card-body">
                @foreach (var week in _weeks.Where(w => !string.IsNullOrWhiteSpace(w.ValueAdded) || !string.IsNullOrWhiteSpace(w.Notes)))
                {
                    <div class="mb-3">
                        <strong>@week.WeekStart.ToString("yyyy-MM-dd") – @week.WeekEnd.ToString("yyyy-MM-dd")</strong>
                        @if (!string.IsNullOrWhiteSpace(week.ValueAdded))
                        {
                            <div class="text-muted small"><span class="fw-semibold">Value Added:</span> @week.ValueAdded</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(week.Notes))
                        {
                            <div class="text-muted small"><span class="fw-semibold">Notes:</span> @week.Notes</div>
                        }
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    private List<AiUsageWeeklyItem> _weeks = [];
    private DateOnly _from = DateOnly.FromDateTime(DateTime.Today.AddDays(-30));
    private DateOnly _to = DateOnly.FromDateTime(DateTime.Today);
    private bool _shouldRenderChart;
    private bool _exporting;
    private string _statusMessage = string.Empty;
    private bool _statusIsError;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_shouldRenderChart) return;
        _shouldRenderChart = false;
        await RenderChart();
    }

    private async Task LoadData()
    {
        if (_from > _to)
        {
            _statusMessage = "From date must be on or before To date.";
            _statusIsError = true;
            return;
        }

        var from = _from.ToDateTime(TimeOnly.MinValue).ToUniversalTime();
        var to = _to.ToDateTime(TimeOnly.MaxValue).ToUniversalTime();
        _weeks = await Handler.GetWeeklyAiUsageAsync(from, to);
        _shouldRenderChart = _weeks.Count > 0;
        _statusMessage = string.Empty;
        _statusIsError = false;
    }

    private async Task RenderChart()
    {
        var labels = _weeks.Select(w => w.WeekStart.ToString("yyyy-MM-dd"));
        var counts = _weeks.Select(w => w.AiTaskCount);
        var totals = _weeks.Select(w => w.TotalTimeSavedMinutes);
        await JS.InvokeVoidAsync("renderAiUsageChart", labels, counts, totals);
    }

    private async Task ExportToObsidian()
    {
        _exporting = true;
        _statusMessage = string.Empty;
        try
        {
            // SettingsHandler exposes GetAsync() — note: not GetSettingsAsync()
            var settings = await SettingsHandler.GetAsync();
            var markdown = ExportService.BuildAiUsageWeeklyReport(_from, _to, _weeks);
            var (path, overwritten) = await ReportsHandler.PushAiUsageReportAsync(_from, _to, markdown, settings);
            _statusIsError = false;
            _statusMessage = overwritten
                ? $"File overwritten at {path}"
                : $"Exported to {path}";
        }
        catch (Exception ex)
        {
            _statusIsError = true;
            _statusMessage = ex.Message;
        }
        finally
        {
            _exporting = false;
        }
    }

    private async Task DownloadMarkdown()
    {
        var markdown = ExportService.BuildAiUsageWeeklyReport(_from, _to, _weeks);
        var filename = $"AI-Usage-Report-{_from:yyyy-MM-dd}-to-{_to:yyyy-MM-dd}.md";
        var base64 = Convert.ToBase64String(Encoding.UTF8.GetBytes(markdown));
        await JS.InvokeVoidAsync("downloadBase64File", filename, base64);
    }
}
