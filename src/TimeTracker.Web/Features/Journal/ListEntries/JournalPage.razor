@page "/journal"
@rendermode InteractiveServer
@implements IDisposable
@inject ListEntriesHandler ListHandler
@inject DeleteJournalEntryHandler DeleteHandler
@inject TimeTracker.Web.Features.Journal.JournalChangeService JournalChangeSvc

<PageTitle>Journal — Time Tracker</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4><i class="bi bi-journal-text me-2"></i>Journal</h4>
</div>

<!-- Filters -->
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label">Type</label>
                <select class="form-select" @bind="_filterType" @bind:after="Refresh">
                    <option value="">All types</option>
                    @foreach (var t in Enum.GetValues<JournalEntryType>())
                    {
                        <option value="@t">@t</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label">From</label>
                <input type="date" class="form-control" @bind="_from" @bind:after="Refresh" />
            </div>
            <div class="col-auto">
                <label class="form-label">To</label>
                <input type="date" class="form-control" @bind="_to" @bind:after="Refresh" />
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-secondary" @onclick="ClearFilters">Clear</button>
            </div>
        </div>
    </div>
</div>

<!-- Entry list -->
@if (_entries.Count == 0)
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-journal-x fs-1 d-block mb-2"></i>
        No entries found.
    </div>
}
else
{
    @foreach (var group in _entries.GroupBy(e => e.Date).OrderByDescending(g => g.Key))
    {
        <h6 class="text-muted mt-3 mb-2">@group.Key.ToString("dddd, MMMM d, yyyy")</h6>
        @foreach (var entry in group)
        {
            var (icon, color) = TypeStyle(entry.Type);
            <div class="card shadow-sm mb-2">
                <div class="card-body py-2">
                    <div class="d-flex align-items-start gap-2">
                        <span class="badge bg-@color mt-1"><i class="bi @icon me-1"></i>@entry.Type</span>
                        <div class="flex-grow-1">
                            <div class="fw-semibold">@entry.Title</div>
                            @if (!string.IsNullOrWhiteSpace(entry.Body))
                            {
                                <p class="text-muted small mb-0">@entry.Body</p>
                            }
                        </div>
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => Delete(entry.Id)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>
            </div>
        }
    }
}

@code {
    private List<JournalEntry> _entries = [];
    private string _filterType = string.Empty;
    private DateOnly? _from;
    private DateOnly? _to;

    protected override async Task OnInitializedAsync()
    {
        JournalChangeSvc.EntryAdded += OnEntryAdded;
        await Refresh();
    }

    private void OnEntryAdded() =>
        InvokeAsync(async () =>
        {
            await Refresh();
            StateHasChanged();
        });

    public void Dispose() => JournalChangeSvc.EntryAdded -= OnEntryAdded;

    private async Task Refresh()
    {
        JournalEntryType? type = Enum.TryParse<JournalEntryType>(_filterType, out var t) ? t : null;
        var filter = new JournalFilter(type, _from, _to);
        _entries = await ListHandler.HandleAsync(filter);
    }

    private async Task Delete(int id)
    {
        await DeleteHandler.HandleAsync(id);
        await Refresh();
    }

    private async Task ClearFilters()
    {
        _filterType = string.Empty;
        _from = null;
        _to = null;
        await Refresh();
    }

    private static (string icon, string color) TypeStyle(JournalEntryType t) => t switch
    {
        JournalEntryType.Challenge => ("bi-lightning-charge", "warning"),
        JournalEntryType.Learning  => ("bi-mortarboard", "info"),
        JournalEntryType.Success   => ("bi-trophy", "success"),
        _ => ("bi-circle", "secondary")
    };
}
