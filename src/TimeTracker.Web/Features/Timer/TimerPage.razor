@page "/timer"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using TimeTracker.Web.Data.Repositories
@inject StartTimerHandler StartHandler
@inject StopTimerHandler StopHandler
@inject GetTodayEntriesHandler TodayHandler
@inject DeleteTimeEntryHandler DeleteHandler
@inject UpdateProductivityHandler ProductivityHandler
@inject UpdateTimeEntryHandler UpdateEntryHandler
@inject ManualEntryHandler ManualHandler
@inject IWorkCategoryRepository _workCategoryRepo
@inject RunningTimerService TimerService
@inject IJSRuntime JS

<PageTitle>Timer — Time Tracker</PageTitle>

<h4 class="mb-4"><i class="bi bi-stopwatch me-2"></i>Timer</h4>

<div class="row g-4">
    <!-- Timer Card -->
    <div class="col-12 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Category</label>
                    <select class="form-select" @bind="_categoryId">
                        <option value="">— Select category —</option>
                        @foreach (var cat in _categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <input class="form-control" placeholder="What are you working on?" @bind="_description" />
                </div>
                <div class="d-flex align-items-center gap-3">
                    <span class="fs-4 fw-bold font-monospace">@_elapsed</span>
                    @if (!TimerService.IsRunning)
                    {
                        <button class="btn btn-success btn-lg" @onclick="StartTimer">
                            <i class="bi bi-play-fill me-1"></i> Start
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-danger btn-lg" @onclick="StopTimer">
                            <i class="bi bi-stop-fill me-1"></i> Stop
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Manual Entry Card -->
    <div class="col-12 col-lg-6">
        <div class="card shadow-sm" id="manual-entry-card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-semibold">Manual Entry</span>
                <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleManualEntry">
                    @(_showManual ? "Hide" : "Show")
                </button>
            </div>
            @if (_showManual)
            {
                <div class="card-body">
                    <div class="row g-2 mb-2">
                        <div class="col-12">
                            <label class="form-label">Start</label>
                            <TimePicker Value="@((DateTime?)_manualStart)" ValueChanged="OnManualStartPickerChanged" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">End</label>
                            <TimePicker Value="@((DateTime?)_manualEnd)" ValueChanged="OnManualEndPickerChanged" />
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Category</label>
                        <select class="form-select" @bind="_manualCategoryId">
                            <option value="">— Select —</option>
                            @foreach (var cat in _categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Description</label>
                        <input class="form-control" @bind="_manualDescription" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Value Added</label>
                        <input class="form-control" @bind="_manualValueAdded" />
                    </div>
                    <div class="form-check mb-2">
                        <input id="manual-is-break" class="form-check-input" type="checkbox" @bind="_manualIsBreak" />
                        <label class="form-check-label" for="manual-is-break">Break Entry</label>
                    </div>
                    <div class="form-check mb-2">
                        <input id="manual-ai-used" class="form-check-input" type="checkbox" @bind="_manualAiUsed" />
                        <label class="form-check-label" for="manual-ai-used">AI-Used</label>
                    </div>
                    @if (_manualAiUsed)
                    {
                        <div class="mb-2">
                            <label class="form-label">Time Saved Using AI (minutes)</label>
                            <input type="number" min="0" class="form-control" @bind="_manualAiTimeSavedMinutes" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">AI Notes</label>
                            <textarea class="form-control" rows="2" @bind="_manualAiNotes"></textarea>
                        </div>
                    }
                    @if (!_manualIsBreak)
                    {
                        <div class="mb-3">
                            <label class="form-label">Productivity</label>
                            <StarRatingPicker Rating="_manualRating" OnRatingChanged="r => _manualRating = r" />
                        </div>
                    }
                    @if (_manualError is not null)
                    {
                        <div class="alert alert-danger py-1">@_manualError</div>
                    }
                    <button class="btn btn-primary" @onclick="SaveManual">Save Entry</button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Today's Entries -->
<div class="card shadow-sm mt-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold"><i class="bi bi-list-ul me-1"></i>Today's Entries</span>
        <span class="text-muted small">Total: <strong>@_totalToday</strong></span>
    </div>
    <div class="card-body p-0">
        @if (_todayEntries.Count == 0)
        {
            <p class="text-muted p-3 mb-0">No entries yet today.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Start</th>
                            <th>End</th>
                            <th>Category</th>
                            <th>Description</th>
                            <th>Value Added</th>
                            <th>Duration</th>
                            <th>Productivity</th>
                            <th>AI Used</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var sorted = _todayEntries.OrderBy(e => e.StartTime).ToList();
                        }
                        @for (int i = 0; i < sorted.Count; i++)
                        {
                            var entry = sorted[i];

                            @if (i > 0 && sorted[i - 1].EndTime.HasValue)
                            {
                                var prevEnd = sorted[i - 1].EndTime!.Value.ToLocalTime();
                                var currStart = entry.StartTime.ToLocalTime();
                                var gapSpan = currStart - prevEnd;
                                @if (gapSpan.TotalMinutes > 2)
                                {
                                    var gapStart = prevEnd;
                                    var gapEnd = currStart;
                                    var gapMins = (int)gapSpan.TotalMinutes;
                                    <tr class="table-warning">
                                        <td colspan="9">
                                            <span class="text-muted fst-italic">
                                                <i class="bi bi-clock-history me-1"></i>
                                                Gap: @gapMins min &nbsp;·&nbsp; @gapStart.ToString("h:mm tt") – @gapEnd.ToString("h:mm tt")
                                            </span>
                                            <button class="btn btn-sm btn-outline-secondary ms-3"
                                                    @onclick="() => StartManualEntryFromGap(gapStart, gapEnd)">
                                                <i class="bi bi-plus-circle me-1"></i>Add Entry
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }

                            <tr>
                                <td class="text-nowrap small">@entry.StartTime.ToLocalTime().ToString("h:mm tt")</td>
                                <td class="text-nowrap small">@(entry.EndTime?.ToLocalTime().ToString("h:mm tt") ?? "—")</td>
                                <td>
                                    @if (entry.WorkCategory is not null)
                                    {
                                        <span class="badge" style="background-color:@entry.WorkCategory.Color">
                                            @entry.WorkCategory.Name
                                        </span>
                                    }
                                </td>
                                <td class="text-muted small">@entry.Description</td>
                                <td class="text-muted small">@entry.ValueAdded</td>
                                <td class="small text-nowrap">@FormatDuration(entry.Duration)</td>
                                <td>
                                    @if (entry.IsBreak)
                                    {
                                        <span class="small text-muted">Break</span>
                                    }
                                    else
                                    {
                                        <StarRatingPicker Rating="@(entry.ProductivityRating ?? 0)"
                                                          OnRatingChanged="r => UpdateRating(entry.Id, r)" />
                                    }
                                </td>
                                <td class="small">
                                    @(entry.AiUsed ? $"Yes ({TimeFormatHelper.FormatMinutes(entry.AiTimeSavedMinutes)})" : "No")
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => BeginEdit(entry)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteEntry(entry.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@if (_editingEntryId.HasValue)
{
    <div class="card shadow-sm mt-3">
        <div class="card-header fw-semibold">Edit Entry</div>
        <div class="card-body">
            <div class="row g-2 mb-2">
                <div class="col-12">
                    <label class="form-label">Start</label>
                    <TimePicker Value="@((DateTime?)_editStart)" ValueChanged="v => { if (v.HasValue) _editStart = v.Value; }" />
                </div>
                <div class="col-12">
                    <label class="form-label">End</label>
                    <TimePicker Value="@((DateTime?)_editEnd)" ValueChanged="v => { if (v.HasValue) _editEnd = v.Value; }" />
                </div>
            </div>
            <div class="mb-2">
                <label class="form-label">Category</label>
                <select class="form-select" @bind="_editCategoryId">
                    <option value="">— Select —</option>
                    @foreach (var cat in _categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </select>
            </div>
            <div class="mb-2">
                <label class="form-label">Description</label>
                <input class="form-control" @bind="_editDescription" />
            </div>
            <div class="mb-2">
                <label class="form-label">Value Added</label>
                <input class="form-control" @bind="_editValueAdded" />
            </div>
            <div class="form-check mb-2">
                <input id="edit-is-break" class="form-check-input" type="checkbox" @bind="_editIsBreak" />
                <label class="form-check-label" for="edit-is-break">Break Entry</label>
            </div>
            <div class="form-check mb-2">
                <input id="edit-ai-used" class="form-check-input" type="checkbox" @bind="_editAiUsed" />
                <label class="form-check-label" for="edit-ai-used">AI-Used</label>
            </div>
            @if (_editAiUsed)
            {
                <div class="mb-2">
                    <label class="form-label">Time Saved Using AI (minutes)</label>
                    <input type="number" min="0" class="form-control" @bind="_editAiTimeSavedMinutes" />
                </div>
                <div class="mb-2">
                    <label class="form-label">AI Notes</label>
                    <textarea class="form-control" rows="2" @bind="_editAiNotes"></textarea>
                </div>
            }
            @if (!_editIsBreak)
            {
                <div class="mb-3">
                    <label class="form-label">Productivity</label>
                    <StarRatingPicker Rating="_editRating" OnRatingChanged="r => _editRating = r" />
                </div>
            }
            @if (_editError is not null)
            {
                <div class="alert alert-danger py-1">@_editError</div>
            }
            <div class="d-flex gap-2">
                <button class="btn btn-primary" @onclick="SaveEdit">Save Changes</button>
                <button class="btn btn-outline-secondary" @onclick="CancelEdit">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private List<WorkCategory> _categories = [];
    private List<TimeEntry> _todayEntries = [];
    private int? _categoryId;
    private string? _description;
    private string _elapsed = "00:00:00";
    private System.Threading.Timer? _ticker;
    private DotNetObjectReference<TimerPage>? _dotNetRef;

    private bool _showManual = false;
    private DateTime _manualStart = DateTime.Now;
    private DateTime _manualEnd = DateTime.Now.AddMinutes(30);
    private bool _manualEndAutoSet = true;
    private int? _manualCategoryId;
    private string? _manualDescription;
    private int _manualRating = 0;
    private string? _manualValueAdded;
    private bool _manualIsBreak;
    private bool _manualAiUsed;
    private int? _manualAiTimeSavedMinutes;
    private string? _manualAiNotes;
    private string? _manualError;

    private int? _editingEntryId;
    private DateTime _editStart = DateTime.Now.AddHours(-1);
    private DateTime _editEnd = DateTime.Now;
    private int? _editCategoryId;
    private string? _editDescription;
    private int _editRating;
    private string? _editValueAdded;
    private bool _editIsBreak;
    private bool _editAiUsed;
    private int? _editAiTimeSavedMinutes;
    private string? _editAiNotes;
    private string? _editError;

    private string _totalToday = "0h 0m";

    protected override async Task OnInitializedAsync()
    {
        _categories = await _workCategoryRepo.GetAllAsync();
        await RefreshEntries();
        await SetManualDefaultsAsync();

        // Sync timer state if already running
        if (TimerService.IsRunning)
        {
            _categoryId = TimerService.CategoryId;
            _description = TimerService.Description;
        }

        _ticker = new System.Threading.Timer(_ =>
        {
            _elapsed = TimerService.GetElapsed().ToString(@"hh\:mm\:ss");
            InvokeAsync(StateHasChanged);
        }, null, 0, 1000);
    }

    private async Task StartTimer()
    {
        StartHandler.Handle(_categoryId, _description);
        await RefreshEntries();
    }

    private async Task StopTimer()
    {
        await StopHandler.HandleAsync();
        _elapsed = "00:00:00";
        _description = null;
        _categoryId = null;
        await RefreshEntries();
    }

    private async Task SaveManual()
    {
        _manualError = null;
        if (_manualEnd <= _manualStart)
        {
            _manualError = "End time must be after start time.";
            return;
        }
        try
        {
            var input = new ManualEntryInput(
                _manualStart.ToUniversalTime(),
                _manualEnd.ToUniversalTime(),
                _manualCategoryId,
                _manualDescription,
                _manualIsBreak ? null : (_manualRating == 0 ? null : _manualRating),
                _manualValueAdded,
                _manualIsBreak,
                _manualAiUsed,
                _manualAiUsed ? _manualAiTimeSavedMinutes : null,
                _manualAiUsed ? _manualAiNotes : null);
            await ManualHandler.HandleAsync(input);
            _showManual = false;
            _manualRating = 0;
            _manualDescription = null;
            _manualValueAdded = null;
            _manualIsBreak = false;
            _manualAiUsed = false;
            _manualAiTimeSavedMinutes = null;
            _manualAiNotes = null;
            await RefreshEntries();
        }
        catch (ArgumentException ex)
        {
            _manualError = ex.Message;
        }
    }

    private async Task DeleteEntry(int id)
    {
        await DeleteHandler.HandleAsync(id);
        await RefreshEntries();
    }

    private async Task UpdateRating(int id, int rating)
    {
        await ProductivityHandler.HandleAsync(id, rating);
        await RefreshEntries();
    }

    private void BeginEdit(TimeEntry entry)
    {
        _editingEntryId = entry.Id;
        _editStart = entry.StartTime.ToLocalTime();
        _editEnd = entry.EndTime?.ToLocalTime() ?? entry.StartTime.ToLocalTime().AddHours(1);
        _editCategoryId = entry.WorkCategoryId;
        _editDescription = entry.Description;
        _editRating = entry.ProductivityRating ?? 0;
        _editValueAdded = entry.ValueAdded;
        _editIsBreak = entry.IsBreak;
        _editAiUsed = entry.AiUsed;
        _editAiTimeSavedMinutes = entry.AiTimeSavedMinutes;
        _editAiNotes = entry.AiNotes;
        _editError = null;
    }

    private void CancelEdit()
    {
        _editingEntryId = null;
        _editError = null;
    }

    private async Task SaveEdit()
    {
        if (!_editingEntryId.HasValue)
            return;

        _editError = null;
        if (_editEnd <= _editStart)
        {
            _editError = "End time must be after start time.";
            return;
        }

        try
        {
            var input = new UpdateTimeEntryInput(
                _editingEntryId.Value,
                _editStart.ToUniversalTime(),
                _editEnd.ToUniversalTime(),
                _editCategoryId,
                _editDescription,
                _editIsBreak ? null : (_editRating == 0 ? null : _editRating),
                _editValueAdded,
                _editIsBreak,
                _editAiUsed,
                _editAiUsed ? _editAiTimeSavedMinutes : null,
                _editAiUsed ? _editAiNotes : null);

            await UpdateEntryHandler.HandleAsync(input);
            _editingEntryId = null;
            await RefreshEntries();
        }
        catch (ArgumentException ex)
        {
            _editError = ex.Message;
        }
    }

    private async Task RefreshEntries()
    {
        _todayEntries = await TodayHandler.HandleAsync();
        var total = _todayEntries
            .Where(e => e.Duration.HasValue)
            .Aggregate(TimeSpan.Zero, (acc, e) => acc + e.Duration!.Value);
        _totalToday = $"{(int)total.TotalHours}h {total.Minutes}m";
    }

    private async Task ToggleManualEntry()
    {
        _showManual = !_showManual;
        if (_showManual)
        {
            await SetManualDefaultsAsync();
        }
    }

    private Task SetManualDefaultsAsync()
    {
        var latestEnd = _todayEntries
            .Where(e => e.EndTime.HasValue)
            .OrderByDescending(e => e.EndTime)
            .Select(e => e.EndTime)
            .FirstOrDefault();

        if (latestEnd.HasValue)
        {
            _manualStart = RoundToNearest15Min(latestEnd.Value.ToLocalTime());
        }
        else
        {
            _manualStart = RoundToNearest15Min(DateTime.Now);
        }

        _manualEnd = _manualStart.AddMinutes(30);
        _manualEndAutoSet = true;
        return Task.CompletedTask;
    }

    private void OnManualStartPickerChanged(DateTime? value)
    {
        if (value.HasValue)
        {
            _manualStart = value.Value;
            if (_manualEndAutoSet)
                _manualEnd = _manualStart.AddMinutes(30);
        }
    }

    private void OnManualEndPickerChanged(DateTime? value)
    {
        if (value.HasValue)
        {
            _manualEnd = value.Value;
            _manualEndAutoSet = false;
        }
    }

    private async Task StartManualEntryFromGap(DateTime gapStart, DateTime gapEnd)
    {
        _showManual = true;
        _manualStart = gapStart;
        _manualEnd = gapEnd;
        _manualEndAutoSet = false;
        StateHasChanged();
        await Task.Delay(50);
        await JS.InvokeVoidAsync("eval", "document.getElementById('manual-entry-card').scrollIntoView({behavior:'smooth'})");
    }

    private static DateTime RoundToNearest15Min(DateTime value)
    {
        var quarterHourTicks = TimeSpan.FromMinutes(15).Ticks;
        var roundedTicks = (value.Ticks + quarterHourTicks / 2) / quarterHourTicks * quarterHourTicks;
        return new DateTime(roundedTicks, value.Kind);
    }

    private static string FormatDuration(TimeSpan? d) =>
        d.HasValue ? $"{(int)d.Value.TotalHours}h {d.Value.Minutes}m" : "—";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("registerTimerShortcut", _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task ToggleTimer()
    {
        if (TimerService.IsRunning)
            await StopTimer();
        else
            await StartTimer();
        await InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        _ticker?.Dispose();
        _dotNetRef?.Dispose();
        await ValueTask.CompletedTask;
    }
}
